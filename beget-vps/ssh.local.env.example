# Шаблон SSH-доступа к VPS Beget.
# 1) Скопируйте:  copy beget-vps\ssh.local.env.example beget-vps\ssh.local.env
# 2) Заполните ssh.local.env своими данными из панели Beget.
# 3) Файл ssh.local.env в Git не попадает (.gitignore).

VPS_HOST=123.45.67.89
VPS_PORT=22
VPS_USER=root
VPS_PASSWORD=

# Необязательно: домен для BlogGPT (после настройки nginx)
VPS_DOMAIN=

# Необязательно: alias для ssh config (см. DEPLOY_BEGET_VPS.txt)
SSH_HOST_ALIAS=beget-bloggpt

# Путь к проекту на сервере
VPS_APP_DIR=/var/www/bloggpt
